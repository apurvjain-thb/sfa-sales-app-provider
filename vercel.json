{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login/:slug", "destination": "/login" },
    { "source": "/profile/:slug", "destination": "/profile" },
    { "source": "/beat-plan/:slug", "destination": "/beat-plan" },
    { "source": "/accounts/:slug", "destination": "/accounts" },
    { "source": "/leads/:slug", "destination": "/leads" },
    { "source": "/deals/:slug", "destination": "/deals" },
    { "source": "/activity/:slug", "destination": "/activity" },
    { "source": "/expenses/:slug", "destination": "/expenses" },
    { "source": "/contacts/:slug", "destination": "/contacts" },
    { "source": "/tasks/:slug", "destination": "/tasks" }
  ],
  "redirects": [
    { "source": "/", "destination": "/login", "permanent": false }
  ]
}
